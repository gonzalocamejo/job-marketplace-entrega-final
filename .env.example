# Red Sepolia
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/TU_PROJECT_ID
PRIVATE_KEY=0xTU_CLAVE_PRIVADA

# Wallet a fondear en la red local (solo para scripts/fondear-cuenta.ts)
FONDEAR_WALLET=0xTU_DIRECCION

# Verificación en Etherscan (opcional)
ETHERSCAN_API_KEY=TU_ETHERSCAN_KEY

# Dirección del token ERC-20 en Sepolia (se completa luego del deploy)
ERC20_TOKEN_ADDRESS=

# Dirección del JobMarketplace en Sepolia (se completa luego del deploy)
JOB_MARKETPLACE_ADDRESS=

# Dirección del Multisig en Sepolia (se completa luego del deploy)
MULTISIG_ADDRESS=

# Frontend (Vite)
VITE_WALLETCONNECT_PROJECT_ID=TU_WALLETCONNECT_PROJECT_ID
VITE_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/TU_PROJECT_ID
VITE_JOB_MARKETPLACE_ADDRESS=
VITE_ERC20_TOKEN_ADDRESS=
